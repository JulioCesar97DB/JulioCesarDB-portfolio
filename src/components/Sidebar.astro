---
import SocialLinks from "@/components/SocialLinks.astro";
import { basics } from "@cv";

const { name, label, location } = basics;
const tagline =
  "I build accessible, high-performance web applications with React, Next.js, and TypeScript.";

const navItems = [
  { id: "about", label: "About" },
  { id: "experience", label: "Experience" },
  { id: "projects", label: "Projects" },
  { id: "skills", label: "Skills" },
  { id: "education", label: "Education" },
  { id: "contact", label: "Contact" },
];
---

<header
  class="lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-[45%] lg:flex-col lg:justify-between lg:py-24"
>
  <div>
    <h1 class="text-4xl font-bold tracking-tight text-slate-lightest sm:text-5xl">
      {name}
    </h1>
    <h2 class="mt-3 text-lg font-medium text-slate-light sm:text-xl">{label}</h2>
    <p class="mt-5 max-w-sm text-base leading-relaxed text-slate">{tagline}</p>
    <p class="mt-3 font-mono text-sm text-slate">
      Based in {location.city}, {location.region}
    </p>

    <nav class="mt-12 hidden lg:block" aria-label="In-page navigation">
      <ul class="space-y-4">
        {
          navItems.map((item) => (
            <li>
              <a
                href={`#${item.id}`}
                data-nav-link
                class="nav-link group flex items-center gap-4 font-mono text-sm uppercase tracking-widest text-slate transition-all duration-300 hover:tracking-[0.2em] hover:text-slate-lightest"
              >
                <span class="nav-indicator h-px w-8 bg-slate transition-all duration-300 group-hover:w-16 group-hover:bg-slate-lightest" />
                <span>{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="mt-8 lg:mt-0">
    <SocialLinks />
  </div>
</header>

<style>
  .nav-link.nav-active {
    color: var(--slate-lightest);
    letter-spacing: 0.2em;
  }
  .nav-link.nav-active .nav-indicator {
    width: 4rem;
    background-color: var(--slate-lightest);
  }
</style>
