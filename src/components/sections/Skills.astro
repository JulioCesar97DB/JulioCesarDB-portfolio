---
import Section from "@/components/Section.astro";
import { getSkillIcon } from "@/utils/icons";
import type { CV } from "@/cv";
import { skills } from "@cv";

type Skill = CV["skills"][number];

const groups = [
  { label: "Expert", items: (skills as Skill[]).filter((skill: Skill) => skill.level === "Expert") },
  { label: "Proficient", items: (skills as Skill[]).filter((skill: Skill) => skill.level !== "Expert") },
];
---

<Section id="skills" number="04" title="Skills & Technologies">
  <div class="space-y-8">
    {
      groups.map((group) => (
        <div data-reveal>
          <h3 class="mb-4 font-mono text-sm uppercase tracking-widest text-accent">
            {group.label}
          </h3>
          <ul class="flex flex-wrap gap-3 [&_svg]:size-5 [&_svg]:text-accent">
            {group.items.map((skill: Skill) => {
              const Icon = getSkillIcon(skill.name);
              return (
                <li class="flex items-center gap-2 rounded-md bg-navy-light/40 px-3 py-2 text-base text-slate-light transition-colors duration-300 hover:text-accent">
                  {Icon && <Icon />}
                  <span>{skill.name}</span>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>
</Section>
