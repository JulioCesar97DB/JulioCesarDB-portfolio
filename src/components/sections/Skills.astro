---
import Section from "@/components/Section.astro";
import type { CV } from "@/cv";
import { skills } from "@cv";

type Skill = CV["skills"][number];

const groups = [
  { label: "Expert", items: (skills as Skill[]).filter((skill: Skill) => skill.level === "Expert") },
  { label: "Proficient", items: (skills as Skill[]).filter((skill: Skill) => skill.level !== "Expert") },
];
---

<Section id="skills" title="Skills & Technologies">
  <div class="space-y-6">
    {
      groups.map((group) => (
        <div>
          <h3 class="mb-3 font-mono text-xs uppercase tracking-widest text-accent">
            {group.label}
          </h3>
          <ul class="flex flex-wrap gap-1.5">
            {group.items.map((skill: Skill) => (
              <li class="tag-badge">{skill.name}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>
