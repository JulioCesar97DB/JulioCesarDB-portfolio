---
import Section from "../Section.astro";
import { getSkillIcon } from "@/utils/icons";
import { skills } from "@cv";
---

<Section className={Astro.props.className} title="Skills">
	<ul
		class="inline-flex flex-wrap gap-3 [&>li>svg]:size-5 [&>li>svg]:text-accent [&>li]:text-sm"
	>
		{
			skills.map(({ name }) => {
				const Icon = getSkillIcon(name);

				return (
					<li class="skill-badge flex items-center gap-1.5 rounded-md border border-accent/15 bg-accent/5 px-2.5 py-1 text-xs text-skin-muted transition-all duration-300 hover:border-accent/40 hover:bg-accent/10 hover:text-accent print:border-none print:bg-transparent print:p-0 print:text-zinc-800">
						{Icon && <Icon />} <span>{name}</span>
					</li>
				);
			})
		}
	</ul>
</Section>

<style>
	.skill-badge:hover {
		box-shadow: 0 0 8px rgba(var(--accent), 0.15);
	}
</style>
