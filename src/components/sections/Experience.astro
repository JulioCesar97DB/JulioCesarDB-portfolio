---
import Section from "../Section.astro"
import ExperienceItem from "./ExperienceItem.astro"
import { work } from "@cv"
---

<Section className={Astro.props.className} title="Experience">
  <ul class="flex flex-col">
    {work.map((job) => (
      <ExperienceItem {...job} />
    ))}
  </ul>
</Section>

<script>
  document.querySelectorAll(".exp-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const peek = btn.previousElementSibling as HTMLElement | null;
      if (!peek) return;

      const isOpen = peek.classList.contains("exp-open");
      const text = btn.querySelector(".exp-toggle-text") as HTMLElement;
      const icon = btn.querySelector(".exp-toggle-icon") as HTMLElement;

      if (isOpen) {
        peek.classList.remove("exp-open");
        peek.style.maxHeight = "";
        text.textContent = "Show more";
        icon.style.transform = "";
      } else {
        peek.classList.add("exp-open");
        peek.style.maxHeight = peek.scrollHeight + "px";
        text.textContent = "Show less";
        icon.style.transform = "rotate(180deg)";
      }
    });
  });
</script>

<style>
  .exp-peek {
    max-height: 72px;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                mask-image 0.4s ease;
    mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
  }

  .exp-peek.exp-open {
    mask-image: none;
    -webkit-mask-image: none;
  }

  .timeline-dot {
    background: radial-gradient(circle at center, rgb(var(--accent)) 0%, rgba(var(--accent), 0.6) 100%);
    box-shadow: 0 0 6px rgba(var(--accent), 0.3);
  }

  li::marker {
    color: rgb(var(--accent));
  }
</style>
