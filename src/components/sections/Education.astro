---
import Section from "@/components/Section.astro";
import GraduationCap from "@/icons/GraduationCap.astro";
import Certificate from "@/icons/Certificate.astro";
import { formatDateRange, getYear } from "@/utils/dates";
import type { CV } from "@/cv";
import { education, certificates } from "@cv";

type Edu = CV["education"][number];
type Cert = CV["certificates"][number];
---

<Section id="education" title="Education & Certifications">
  <div class="group/list space-y-6">
    {
      (education as Edu[]).map((edu: Edu) => (
        <article
          data-reveal
          class="glass-card p-5 lg:group-hover/list:opacity-50 lg:hover:!opacity-100"
        >
          <div class="flex items-start gap-3">
            <div class="mt-1 text-accent [&_svg]:size-6">
              <GraduationCap />
            </div>
            <div class="space-y-1">
              <h3 class="font-semibold text-slate-lightest">
                {edu.studyType} in {edu.area}
              </h3>
              <a
                href={edu.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-base text-accent hover:underline"
              >
                {edu.institution}
              </a>
              <p class="font-mono text-xs text-slate">
                {formatDateRange(edu.startDate, edu.endDate)} · GPA {edu.score}
              </p>
            </div>
          </div>
        </article>
      ))
    }
    {
      (certificates as Cert[]).map((cert: Cert) => (
        <article
          data-reveal
          class="glass-card p-5 lg:group-hover/list:opacity-50 lg:hover:!opacity-100"
        >
          <div class="flex items-start gap-3">
            <div class="mt-1 text-accent [&_svg]:size-6">
              <Certificate />
            </div>
            <div class="space-y-1">
              <h3 class="font-semibold text-slate-lightest">{cert.name}</h3>
              <a
                href={cert.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-base text-accent hover:underline"
              >
                {cert.issuer}
              </a>
              <p class="font-mono text-xs text-slate">{getYear(cert.date)}</p>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</Section>
