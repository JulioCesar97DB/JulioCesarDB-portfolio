---
import Section from "@/components/Section.astro";
import FeaturedProject from "@/components/FeaturedProject.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import type { CV } from "@/cv";
import { projects } from "@cv";

type Project = CV["projects"][number];

const featured = (projects as Project[]).filter((project: Project) => project.isActive).slice(0, 5);
const noteworthy = (projects as Project[]).filter((project: Project) => !featured.includes(project));
---

<Section id="projects" title="Some Things I've Built">
  <div class="group/list space-y-4">
    {featured.map((project: Project) => <FeaturedProject {...project} />)}
  </div>

  {
    noteworthy.length > 0 && (
      <>
        <h3
          class="mb-6 mt-12 text-center font-mono text-base text-slate-lightest"
          data-reveal
        >
          Other Noteworthy Projects
        </h3>
        <ul class="group/list grid gap-4 sm:grid-cols-2">
          {noteworthy.map((project: Project) => (
            <ProjectCard {...project} />
          ))}
        </ul>
      </>
    )
  }

  <div class="mt-12 text-center" data-reveal>
    <a
      href="/archive"
      class="inline-flex items-center gap-2 rounded border border-accent px-6 py-3 font-mono text-sm text-accent transition-colors hover:bg-accent/10"
    >
      View Full Project Archive
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</Section>
