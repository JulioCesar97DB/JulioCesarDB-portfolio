---
import { formatDateRange } from "@/utils/dates";
import ExternalLink from "@/icons/ExternalLink.astro";

interface Props {
  name: string;
  position: string;
  url: string;
  startDate: string;
  endDate: string | null;
  summary: string;
  location?: string;
  location_type?: string;
  responsibilities?: string[];
  achievements?: string[];
  skills?: string[];
}

const {
  name,
  position,
  url,
  startDate,
  endDate,
  summary,
  location,
  location_type,
  responsibilities = [],
  achievements = [],
  skills = [],
} = Astro.props;

const dateRange = formatDateRange(startDate, endDate);
const place = [location_type, location].filter(Boolean).join(" · ");
const hasDetails = responsibilities.length > 0 || achievements.length > 0;
---

<li
  class="sibling-dim transition-opacity duration-300"
>
  <div
    class="glass-card group grid gap-1 p-4 sm:grid-cols-[120px_1fr] sm:gap-5"
  >
    <p class="pt-1 font-mono text-xs uppercase tracking-wide text-slate">{dateRange}</p>
    <div class="space-y-2">
      <h3 class="text-base font-semibold text-slate-lightest">
        <span>{position}</span>
        {
          url ? (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-accent transition-colors hover:underline"
            >
              · {name}
              <ExternalLink class="h-3 w-3" />
            </a>
          ) : (
            <span class="text-accent"> · {name}</span>
          )
        }
      </h3>
      {place && <p class="font-mono text-xs text-slate">{place}</p>}
      <p class="text-sm leading-normal text-slate">{summary}</p>

      {
        hasDetails && (
          <details>
            <summary class="inline-flex cursor-pointer list-none items-center gap-1 font-mono text-xs text-accent hover:underline">
              View details
            </summary>
            <div class="mt-3 space-y-3">
              {responsibilities.length > 0 && (
                <ul class="space-y-1.5">
                  {responsibilities.map((item) => (
                    <li class="relative pl-5 text-sm text-slate before:absolute before:left-0 before:text-accent before:content-['▹']">
                      {item}
                    </li>
                  ))}
                </ul>
              )}
              {achievements.length > 0 && (
                <ul class="space-y-1.5">
                  {achievements.map((item) => (
                    <li class="relative pl-5 text-sm text-slate before:absolute before:left-0 before:text-accent before:content-['★']">
                      {item}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </details>
        )
      }

      {
        skills.length > 0 && (
          <ul class="flex flex-wrap gap-2 pt-1">
            {skills.map((skill) => (
              <li class="tag-badge">{skill}</li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</li>
