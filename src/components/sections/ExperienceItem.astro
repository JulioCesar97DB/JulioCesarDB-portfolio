---
import ExternalLink from "@/icons/ExternalLink.astro";
import { getSkillIcon } from "@/utils/icons";
import { formatDateRange } from "@/utils/dates";

interface Props {
	name: string;
	startDate: string;
	endDate: string | null;
	position: string;
	summary?: string;
	responsibilities?: string[];
	achievements?: string[];
	url?: string;
	skills?: string[];
	location?: string;
	location_type?: string;
}

const { name, startDate, endDate, position, summary, responsibilities, achievements, url, skills, location, location_type } = Astro.props;

const dateRange = formatDateRange(startDate, endDate);
const startYear = new Date(startDate).getFullYear();
const endYear = endDate != null ? new Date(endDate).getFullYear() : "Present";
---

<li class="relative print:py-2">
	<div class="group relative grid pb-1 print:pb-0 print:grid-cols-1 print:gap-1 md:grid-cols-12 md:gap-6">
		<header class="relative mt-1 font-mono text-xs text-skin-muted md:col-span-2">
			<time datetime={startDate} data-title={startDate}>{startYear}</time> - <time datetime={endDate} data-title={endDate}>{endYear}</time>
		</header>
		<div class="relative flex flex-col pb-6 print:pb-0 md:before:-ml-6 md:col-span-10 before:w-px print:before:hidden before:absolute before:bg-gradient-to-b before:from-accent/40 before:to-accent/5 before:h-full before:mt-2 before:hidden md:before:block">
			<div class="timeline-dot absolute w-2 h-2 rounded-full mt-2 -translate-x-[1.71rem] ring-2 print:hidden ring-skin-fill hidden md:block"></div>
			<h3>
				<div class="inline-flex items-center text-lg print:text-base leading-tight group/link" aria-label={`${position} at ${name}`}>
					<span>{position} <span class="text-accent">@</span>{" "}
					{url ? (
						<a class="text-accent hover:underline decoration-dotted underline-offset-4" href={url} title={`Visit ${name}`} target="_blank" rel="noopener noreferrer">{name}</a>
					) : (
						<span>{name}</span>
					)}
					{url &&
						<span class="inline-block text-accent print:[&>svg]:hidden">
							<ExternalLink />
						</span>
					}
					</span>
				</div>
			</h3>
			{(location || location_type) && (
				<div class="font-mono text-xs text-skin-muted">
					{location} {location && location_type && '-'} {location_type}
				</div>
			)}
			<div class="mt-4 print:gap-0 flex flex-col gap-4 print:text-xs text-sm">
				{summary && (
					<p class="text-skin-muted border-l border-accent/15 pl-4 leading-relaxed">
						{summary}
					</p>
				)}

				{(responsibilities || achievements) && (
					<div class="exp-peek relative print:!max-h-none print:[mask-image:none]">
						<div class="flex flex-col gap-4 print:gap-2">
							{responsibilities && (
								<div class="flex flex-col gap-1.5">
									<h4 class="text-xs font-semibold uppercase tracking-wider text-accent/70">Responsibilities</h4>
									<ul class="text-skin-muted [&>li]:ml-4 flex list-disc flex-col gap-1.5">
										{responsibilities.map(responsibility => (
											<li>{responsibility}</li>
										))}
									</ul>
								</div>
							)}

							{achievements && (
								<div class="flex flex-col gap-1.5">
									<h4 class="text-xs font-semibold uppercase tracking-wider text-accent/70">Achievements</h4>
									<ul class="text-skin-muted [&>li]:ml-4 flex list-disc flex-col gap-1.5">
										{achievements.map(achievement => (
											<li>{achievement}</li>
										))}
									</ul>
								</div>
							)}
						</div>
					</div>

					<button class="exp-toggle print:hidden group/more w-fit cursor-pointer items-center justify-center gap-1.5 text-xs text-accent/70 transition-all hover:text-accent flex mt-1" aria-label="Toggle details">
						<span class="exp-toggle-text">Show more</span>
						<svg class="w-4 h-4 exp-toggle-icon transition-transform duration-300 ease-out group-hover/more:translate-y-0.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="6 9 12 15 18 9"></polyline>
						</svg>
					</button>
				)}

				<ul class="flex print:hidden flex-wrap gap-2" aria-label="Technologies used">
					{skills && skills.map(skill => {
						const Icon = getSkillIcon(skill);
						return (
							<li class="bg-accent/5 border-accent/20 text-accent print:p-0 print:bg-transparent print:text-zinc-800 flex gap-1 items-center border border-solid print:border-none rounded-md px-2 py-0.5 text-xs transition-colors duration-200 hover:bg-accent/10 hover:border-accent/40">
								{Icon && <Icon />} <span>{skill}</span>
							</li>
						)
					})}
				</ul>
			</div>
		</div>
	</div>
</li>
