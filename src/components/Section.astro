---
interface Props {
  id: string;
  title: string;
  class?: string;
}

const { id, title, class: className } = Astro.props;
---

<section id={id} class:list={["scroll-mt-24", className]}>
  <h2
    class="mb-6 flex items-center gap-3 text-xl font-bold text-slate-lightest sm:text-2xl"
  >
    <span>{title}</span>
    <span class="ml-4 hidden h-px max-w-xs flex-1 bg-navy-lightest sm:block"></span>
  </h2>
  <slot />
</section>
