---
import "@fontsource-variable/inter/wght.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@/styles/global.css";
import { basics } from "@cv";

interface Props {
  title: string;
}

const { title } = Astro.props;
const { image, summary, url } = basics;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={url} />

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summary} />
    <meta property="og:image" content={`${url}${image}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image" content={`${url}${image}`} />

    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <div id="spotlight" aria-hidden="true"></div>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:font-mono focus:text-sm focus:text-navy"
    >
      Skip to content
    </a>
    <slot />
    <script>
      import { initSpotlight } from "@/scripts/spotlight";
      import { initReveal } from "@/scripts/reveal";
      initSpotlight();
      initReveal();
    </script>
  </body>
</html>
